# ChunkPilot 后端配置示例。复制为 .env 后按需修改（也可用同名环境变量覆盖）。
# 所有变量前缀为 RAG_。

# 嵌入来源：api = 调独立 GPU 服务；local = 后端进程内跑 BGE-M3（需安装 local 可选依赖组）
RAG_EMBEDDING_MODE=api

# api 模式下的 GPU 推理服务地址（embedding_service）
RAG_EMBEDDING_SERVICE_URL=http://localhost:8001

# local 模式使用的模型
RAG_LOCAL_EMBED_MODEL=BAAI/bge-m3
RAG_LOCAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Qdrant 地址（Docker 内通常为 http://qdrant:6333）
RAG_QDRANT_URL=http://localhost:6333

# 文档存储与运行时数据目录
# RAG_DOCS_DIR=/app/docs
# RAG_DATA_DIR=/app/data

# 调推理服务的分批大小与超时
RAG_EMBED_BATCH=64
RAG_REQUEST_TIMEOUT=120
